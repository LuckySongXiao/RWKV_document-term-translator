<Window x:Class="DocumentTranslator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RWKV文档术语翻译助手 v3.1"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- 样式定义 -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Padding" Value="15"/>
        </Style>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="StatusStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 菜单栏 -->
        <Menu Grid.Row="0">
            <MenuItem Header="设置(_S)">
                <MenuItem Header="RWKV_lightning设置" Click="OpenrwkvSettings"/>
                <MenuItem Header="llama_cpp设置" Click="OpenLlamaCppSettings"/>
            </MenuItem>
            <MenuItem Header="工具(_T)">
                <MenuItem Header="翻译助手(_T)" Click="OpenTranslationAssistant"/>
            </MenuItem>

            <MenuItem Header="帮助(_H)">
                <MenuItem Header="授权信息" Click="ShowLicenseInfo"/>
                <MenuItem Header="关于" Click="ShowAbout"/>
            </MenuItem>
        </Menu>

        <!-- 主内容区域 -->
        <Grid Grid.Row="1" Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧控制面板 -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- 系统状态卡片 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📊 系统状态" Style="{StaticResource HeaderStyle}"/>
                            <TextBlock x:Name="StatusText" Text="🟢 系统就绪" Style="{StaticResource StatusStyle}" Foreground="Green"/>
                            <ProgressBar x:Name="TranslationProgress" Height="20" Margin="0,10,0,0" Visibility="Collapsed"/>
                            <TextBlock x:Name="ProgressText" Style="{StaticResource StatusStyle}" Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- 文档管理卡片 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="📁 文档管理" Style="{StaticResource HeaderStyle}"/>
                            <TextBox x:Name="FilePathText" IsReadOnly="True" Margin="0,5" Height="25"/>
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <Button Content="🔍 选择文件" Click="SelectFile" Width="100" Margin="0,0,5,0"/>
                                <Button Content="🗑️ 清除" Click="ClearFile" Width="80"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 翻译配置卡片 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🌐 翻译配置" Style="{StaticResource HeaderStyle}"/>

                            <!-- 翻译方向 -->
                            <TextBlock Text="🔄 翻译方向" FontWeight="Bold" Margin="0,5"/>
                            <RadioButton x:Name="ChineseToForeign" Content="🇨🇳 中文 → 外语" IsChecked="True" Margin="0,2"/>
                            <RadioButton x:Name="ForeignToChinese" Content="🌍 外语 → 中文" Margin="0,2"/>

                            <!-- 目标语言 -->
                            <TextBlock Text="🗣️ 目标语言" FontWeight="Bold" Margin="0,10,0,5"/>
                            <ComboBox x:Name="LanguageCombo" Height="25" SelectedIndex="0">
                                <ComboBoxItem Content="英语"/>
                                <ComboBoxItem Content="日语"/>
                                <ComboBoxItem Content="韩语"/>
                                <ComboBoxItem Content="法语"/>
                                <ComboBoxItem Content="德语"/>
                                <ComboBoxItem Content="西班牙语"/>
                                <ComboBoxItem Content="越南语"/>
                                <ComboBoxItem Content="意大利语"/>
                                <ComboBoxItem Content="俄语"/>
                            </ComboBox>
                        </StackPanel>
                    </Border>

                    <!-- 本地模型管理卡片 -->
                    <Border Style="{StaticResource CardStyle}" Background="#E3F2FD">
                        <StackPanel>
                            <TextBlock Text="🎮 本地模型管理" Style="{StaticResource HeaderStyle}" Foreground="#1565C0"/>
                            
                            <!-- 服务状态 -->
                            <StackPanel Orientation="Horizontal" Margin="0,5">
                                <TextBlock Text="状态: " FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="LocalServiceStatusText" Text="⏹️ 已停止" VerticalAlignment="Center" Foreground="#666666"/>
                            </StackPanel>

                            <!-- GPU选择 -->
                            <TextBlock Text="🖥️ 选择GPU" FontWeight="Bold" Margin="0,8,0,3"/>
                            <ComboBox x:Name="GpuSelectorCombo" Height="25" Margin="0,2">
                                <ComboBoxItem Content="正在检测GPU..."/>
                            </ComboBox>

                            <!-- 模型选择 -->
                            <TextBlock Text="📦 选择模型" FontWeight="Bold" Margin="0,8,0,3"/>
                            <ComboBox x:Name="ModelSelectorCombo" Height="25" Margin="0,2">
                                <ComboBoxItem Content="正在扫描模型..."/>
                            </ComboBox>

                            <!-- 推理工具选择 -->
                            <TextBlock Text="🔧 推理工具" FontWeight="Bold" Margin="0,8,0,3"/>
                            <ComboBox x:Name="InferenceToolCombo" Height="25" Margin="0,2" SelectedIndex="0" SelectionChanged="InferenceToolCombo_SelectionChanged">
                                <ComboBoxItem Content="rwkv_lightning.exe (推荐 - 完整翻译API服务)"/>
                                <ComboBoxItem Content="benchmark.exe (性能测试 - 不提供翻译API)"/>
                                <ComboBoxItem Content="llama-server.exe [CUDA] (GGUF模型 - NVIDIA GPU)"/>
                                <ComboBoxItem Content="llama-server.exe [SYCL] (GGUF模型 - Intel GPU)"/>
                                <ComboBoxItem Content="llama-server.exe [Vulkan] (GGUF模型 - AMD/通用GPU)"/>
                                <ComboBoxItem Content="llama-server.exe [CPU] (GGUF模型 - 纯CPU推理)"/>
                            </ComboBox>
                            <TextBlock x:Name="InferenceToolDescription" Text="💡 rwkv_lightning.exe 提供完整的翻译API服务；llama-server.exe 使用GGUF格式模型" FontSize="10" Foreground="Gray" Margin="0,4,0,0" TextWrapping="Wrap"/>

                            <!-- ModelScope下载地址 -->
                            <TextBlock Text="🌐 ModelScope下载地址" FontWeight="Bold" Margin="0,8,0,3"/>
                            <TextBox x:Name="ModelScopeUrlText" Height="25" Margin="0,2" 
                                     Text="https://www.modelscope.cn/models/AlicLi/rwkv7-g1-libtorch-st/files"
                                     ToolTip="可修改为其他ModelScope模型仓库地址，格式: https://www.modelscope.cn/models/{Owner}/{ModelName}/files"/>
                            <TextBlock x:Name="ModelScopeUrlHint" Text="💡 可修改为其他ModelScope模型仓库地址" 
                                       FontSize="10" Foreground="Gray" Margin="0,2,0,0" TextWrapping="Wrap"/>

                            <!-- 模型下载按钮 -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="DownloadModelBtn" Content="📥 从ModelScope下载模型" 
                                        Click="DownloadModelFromSite" Width="180" Height="28"
                                        Background="#FF9800" Foreground="White" FontWeight="Bold"/>
                                <Button x:Name="CancelDownloadBtn" Content="❌ 取消" 
                                        Click="CancelModelDownload" Width="70" Height="28"
                                        Background="#9E9E9E" Foreground="White" IsEnabled="False" Margin="8,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button x:Name="ImportLocalModelBtn" Content="📂 导入本地模型" 
                                        Click="ImportLocalModel" Width="120" Height="28"
                                        Background="#03A9F4" Foreground="White" FontWeight="Bold"/>
                                <Button x:Name="ConvertSelectedModelBtn" Content="🔄 转换选中.pth" 
                                        Click="ConvertSelectedPthModel" Width="120" Height="28"
                                        Background="#9C27B0" Foreground="White" FontWeight="Bold" Margin="8,0,0,0"/>
                            </StackPanel>

                            <!-- 下载进度条 -->
                            <ProgressBar x:Name="ModelDownloadProgress" Height="16" Margin="0,6,0,0" 
                                         Visibility="Collapsed" Background="#E0E0E0"/>
                            <TextBlock x:Name="DownloadProgressText" Text="" FontSize="10" 
                                       Foreground="#1565C0" Margin="0,2,0,0" TextWrapping="Wrap"
                                       Visibility="Collapsed"/>

                            <!-- 并发数显示 -->
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,3">
                                <TextBlock Text="⚡ 建议并发: " FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SuggestedConcurrencyText" Text="-" VerticalAlignment="Center" Foreground="#2196F3"/>
                            </StackPanel>

                            <!-- BSZ 上限测试选项 -->
                            <CheckBox x:Name="EnableBszTestCheck" Content="🧪 启动后自动执行 BSZ 上限测试" 
                                      Margin="0,8,0,3" FontSize="12"/>
                            <TextBlock Text="勾选后将在启动模型后自动测试短/中/长 prompt 场景的极限 BSN" 
                                       FontSize="10" Foreground="Gray" Margin="0,0,0,8" TextWrapping="Wrap"/>

                            <!-- BSZ 测试增量值 -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                <TextBlock Text="📈 BSZ 测试增量: " FontWeight="Bold" VerticalAlignment="Center" Width="100"/>
                                <TextBox x:Name="BszIncrementText" Text="10" Width="60" Height="25" 
                                         TextAlignment="Center" VerticalContentAlignment="Center"
                                         PreviewTextInput="BszIncrementText_PreviewTextInput"/>
                                <TextBlock Text=" (每次递增的 batch size 数量)" FontSize="10" 
                                           Foreground="Gray" VerticalAlignment="Center" Margin="5,0,0,0"/>
                            </StackPanel>

                            <!-- 控制按钮 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button x:Name="StartLocalModelBtn" Content="🚀 启动本地模型" 
                                        Click="StartLocalModel" Width="130" Height="32" 
                                        Background="#4CAF50" Foreground="White" FontWeight="Bold" Margin="0,0,8,0"/>
                                <Button x:Name="StopLocalModelBtn" Content="⏹️ 停止" 
                                        Click="StopLocalModel" Width="80" Height="32" 
                                        Background="#f44336" Foreground="White" IsEnabled="False" Margin="0,0,8,0"/>
                                <Button x:Name="RefreshModelsBtn" Content="🔄 刷新" 
                                        Click="RefreshLocalModels" Width="60" Height="32"/>
                            </StackPanel>

                            <!-- 资源监控 -->
                            <Border Background="#BBDEFB" CornerRadius="4" Padding="8" Margin="0,10,0,0">
                                <StackPanel>
                                    <TextBlock x:Name="LocalModelInfoText" Text="💡 启动后自动计算最优并发数" 
                                               FontSize="11" Foreground="#1565C0" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="GpuMemoryText" Text="" 
                                               FontSize="11" Foreground="#1565C0" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- AI翻译引擎卡片 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="🤖 RWKV翻译引擎" Style="{StaticResource HeaderStyle}"/>

                            <!-- 当前API地址 -->
                            <TextBlock Text="🔗 API地址" FontWeight="Bold" Margin="0,10,0,5"/>
                            <TextBox x:Name="ApiUrlDisplay" Height="25" IsReadOnly="True" Background="#F0F0F0" Foreground="Gray"/>

                            <!-- 连接测试 -->
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="🧪 测试连接" Click="TestConnection" Width="100"/>
                                <TextBlock x:Name="TestStatusText" Text="🔍 未测试" Style="{StaticResource StatusStyle}" Margin="10,0"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 翻译选项卡片 -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="⚙️ 翻译选项" Style="{StaticResource HeaderStyle}"/>
                            <CheckBox x:Name="UseTerminology" Content="✅ 使用术语库进行翻译" IsChecked="True" Margin="0,2"/>
                            <CheckBox x:Name="PreprocessTerms" Content="⚡ 使用术语预处理" IsChecked="True" Margin="0,2"/>
                            <CheckBox x:Name="ExportPDF" Content="📄 同时导出PDF文件" Margin="0,2"/>
                            <CheckBox x:Name="UseBOMTranslation" Content="📊 使用BOM表专属翻译功能" Margin="0,2" ToolTip="适用于BOM表等结构化表格的高效翻译模式"/>

                            <!-- 输出格式选项 -->
                            <TextBlock Text="📋 输出格式" FontWeight="Bold" Margin="0,10,0,5"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2">
                                <RadioButton x:Name="BilingualOutput" Content="📋 双语对照" GroupName="OutputFormat" IsChecked="True" Margin="0,0,10,0"/>
                                <RadioButton x:Name="TranslationOnlyOutput" Content="📝 仅输出译文" GroupName="OutputFormat" Margin="0,0,10,0"/>
                                <Button Content="⚙️ 高级配置" Click="OpenOutputConfigWindow" Width="100" Height="25"/>
                            </StackPanel>
                            <TextBlock Text="💡 双语对照便于对比，纯译文保留原排版更简洁"
                                       FontSize="10" Foreground="Gray" Margin="0,2,0,10" TextWrapping="Wrap"/>

                            <Button Content="📝 打开术语库编辑器" Click="OpenTerminologyEditor" Margin="0,5,0,0" Height="30"/>
                        </StackPanel>
                    </Border>

                        <!-- 性能设置卡片 -->
                        <Border Style="{StaticResource CardStyle}">
                            <StackPanel>
                                <TextBlock Text="⚡ 性能与并发" Style="{StaticResource HeaderStyle}"/>

                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,5">
                                    <TextBlock Text="🧮 建议并发:" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="SuggestedParallelText" Text="-" FontWeight="Bold" Margin="8,0,0,0"/>
                                </StackPanel>

                                <TextBlock Text="🧰 手动设置最大并发" FontWeight="Bold" Margin="0,5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                    <Slider x:Name="ParallelismSlider" Minimum="1" Maximum="1000" Value="4" TickFrequency="10" IsSnapToTickEnabled="True" Height="24" Width="250"/>
                                    <TextBox x:Name="ParallelismInput" Text="4" Width="50" Margin="10,0,0,0" HorizontalContentAlignment="Center"/>
                                </StackPanel>
                                <TextBlock x:Name="ParallelismValueText" Text="并发: 4" HorizontalAlignment="Right" Margin="0,2,0,0"/>

                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Button Content="🔍 检测本机资源" Click="DetectResources" Width="120" Margin="0,0,8,0"/>
                                    <Button Content="💾 应用并发设置" Click="ApplyParallelism" Width="120"/>
                                </StackPanel>

                                <TextBlock Text="📦 每批次并发上限" FontWeight="Bold" Margin="0,10,0,3"/>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,3">
                                    <TextBox x:Name="BatchConcurrencyLimitText" Text="50" Width="60" Height="25" 
                                             TextAlignment="Center" VerticalContentAlignment="Center"
                                             PreviewTextInput="BszIncrementText_PreviewTextInput"/>
                                    <TextBlock Text=" GPU资源超警戒时每批最大并发数（0=不限）" FontSize="10" 
                                               Foreground="Gray" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>

                                <TextBlock Text="💡 并发设置只对RWKV引擎有效，控制同一秒内提交的最大不同文本内容数。GPU/显存占用超95%时按批次上限分批发送请求。" FontSize="10" Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>


                    <!-- 开始翻译卡片 -->
                    <Border Style="{StaticResource CardStyle}" Background="#FFEBEE">
                        <StackPanel>
                            <TextBlock Text="🚀 开始翻译" Style="{StaticResource HeaderStyle}"/>
                            <Button x:Name="TranslateButton" Content="🚀 开始翻译" Click="StartTranslation"
                                    Height="40" FontSize="14" FontWeight="Bold" Background="#4CAF50" Foreground="White"/>
                            <TextBlock Text="💡 请确保已选择文件、设置翻译方向和检查翻译器状态"
                                       Style="{StaticResource StatusStyle}" Foreground="Gray" TextWrapping="Wrap" Margin="0,5"/>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧日志面板 -->
            <Border Grid.Column="1" Style="{StaticResource CardStyle}" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 实时日志" Style="{StaticResource HeaderStyle}"/>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <TextBox x:Name="LogTextBox" IsReadOnly="True" TextWrapping="Wrap"
                                 Background="Black" Foreground="LightGreen" FontFamily="Consolas" FontSize="11"
                                 VerticalScrollBarVisibility="Auto"/>
                    </ScrollViewer>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5,0,0">
                        <Button Content="📁 打开输出目录" Click="OpenOutputDirectory" Width="120" Height="30" Margin="0,0,5,0"/>
                        <Button Content="💾 保存日志" Click="SaveLog" Width="90" Height="30" Margin="0,0,5,0"/>
                        <Button Content="🗑️ 清除日志" Click="ClearLog" Width="90" Height="30"/>
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- 状态栏 -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock x:Name="StatusBarText" Text="就绪"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <TextBlock Text="RWKV文档术语翻译助手 v3.1"/>
            </StatusBarItem>
        </StatusBar>

    </Grid>
</Window>
