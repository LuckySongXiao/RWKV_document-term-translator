<Window x:Class="DocumentTranslator.Windows.ModelSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="选择要下载的模型" Height="450" Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#3498DB" Padding="12">
            <StackPanel>
                <TextBlock x:Name="TitleText" Text="选择要下载的模型" FontSize="16" FontWeight="Bold" Foreground="White"/>
                <TextBlock x:Name="SourceText" Text="" FontSize="11" Foreground="#D5DBDB" Margin="0,4,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- 模型列表 -->
        <Grid Grid.Row="1" Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            
            <!-- 全选/取消全选 -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <CheckBox x:Name="SelectAllCheckBox" Content="全选" VerticalAlignment="Center" 
                          Checked="SelectAllChanged" Unchecked="SelectAllChanged" Margin="0,0,16,0"/>
                <TextBlock x:Name="SummaryText" Text="" VerticalAlignment="Center" FontSize="12" Foreground="#7F8C8D"/>
            </StackPanel>
            
            <!-- 文件列表 -->
            <ListView Grid.Row="1" x:Name="FileListView" SelectionMode="Multiple">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Width="40">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                              Checked="ItemSelectionChanged" Unchecked="ItemSelectionChanged"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="文件名" Width="280">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}" ToolTip="{Binding FileName}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="大小" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Size}" HorizontalAlignment="Right"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="12">
            <Grid>
                <TextBlock x:Name="TotalSizeText" Text="" VerticalAlignment="Center" FontSize="12" Foreground="#2C3E50"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="下载选中" Click="DownloadSelected" Width="100" Height="30" Margin="0,0,10,0"
                            Background="#3498DB" Foreground="White" FontWeight="Bold"/>
                    <Button Content="取消" Click="CancelDownload" Width="80" Height="30"
                            Background="#9E9E9E" Foreground="White"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
