<Window x:Class="DocumentTranslator.Windows.EngineConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="AI引擎配置" Height="500" Width="600"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    
    <Window.Resources>
        <Style x:Key="ConfigCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8F9FA"/>
            <Setter Property="BorderBrush" Value="#E9ECEF"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="15"/>
        </Style>
        
        <Style x:Key="ConfigHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#3498DB" Padding="15">
            <TextBlock Text="🤖 AI引擎配置管理" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>
        
        <!-- 配置选项卡 -->
        <TabControl Grid.Row="1" Margin="10">

            <!-- RWKV_lightning配置 -->
            <TabItem Header="🤖 RWKV_lightning">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ConfigCardStyle}">
                        <StackPanel>
                            <TextBlock Text="RWKV_lightning配置" Style="{StaticResource ConfigHeaderStyle}"/>

                            <TextBlock Text="API地址" FontWeight="Bold" Margin="0,5"/>
                            <ComboBox x:Name="rwkvApiUrl" Height="35" Margin="0,2,0,10" IsEditable="True">
                                <ComboBoxItem Content="http://localhost:8000/translate/v1/batch-translate"/>
                                <ComboBoxItem Content="http://localhost:8000/v1/chat/completions"/>
                                <ComboBoxItem Content="http://localhost:8000/v2/chat/completions"/>
                            </ComboBox>

                            <CheckBox x:Name="rwkvUseBatchTranslate" Content="使用批量翻译API (/translate/v1/batch-translate)" Margin="0,5"/>

                            <TextBlock Text="温度参数 (0.0-1.0)" FontWeight="Bold" Margin="0,5"/>
                            <Slider x:Name="rwkvTemperature" Minimum="0" Maximum="1" Value="0.3"
                                    TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,2,0,5"/>
                            <TextBlock Text="{Binding ElementName=rwkvTemperature, Path=Value, StringFormat=F1}"
                                       HorizontalAlignment="Center" Margin="0,0,0,10"/>

                            <TextBlock Text="最大令牌数" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="rwkvMaxTokens" Text="4000" Height="35" Margin="0,2,0,10"/>

                            <CheckBox x:Name="rwkvSkipSSL" Content="跳过SSL验证" Margin="0,5"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="🧪 测试连接" Click="TestrwkvConnection" Width="100" Margin="0,0,10,0"/>
                                <Button Content="💾 保存配置" Click="SaverwkvConfig" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

            <!-- llama_cpp配置 -->
            <TabItem Header="🦙 llama_cpp">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Border Style="{StaticResource ConfigCardStyle}">
                        <StackPanel>
                            <TextBlock Text="llama_cpp配置" Style="{StaticResource ConfigHeaderStyle}"/>

                            <!-- API接口设置 -->
                            <TextBlock Text="API接口设置" FontWeight="Bold" FontSize="13" Foreground="#3498DB" Margin="0,0,0,8"/>

                            <TextBlock Text="API地址" FontWeight="Bold" Margin="0,5"/>
                            <ComboBox x:Name="llamaCppApiUrl" Height="35" Margin="0,2,0,10" IsEditable="True">
                                <ComboBoxItem Content="http://127.0.0.1:8080/v1/completions"/>
                                <ComboBoxItem Content="http://127.0.0.1:8080/v1/chat/completions"/>
                            </ComboBox>

                            <TextBlock Text="推理模式" FontWeight="Bold" Margin="0,5"/>
                            <ComboBox x:Name="llamaCppMode" Height="35" Margin="0,2,0,10">
                                <ComboBoxItem Content="Completions (续写模式)" Tag="completions"/>
                                <ComboBoxItem Content="Chat (对话模式)" Tag="chat"/>
                            </ComboBox>

                            <TextBlock Text="对话模板 (chat-template)" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppChatTemplate" Text="rwkv-world" Height="35" Margin="0,2,0,10"/>
                            <TextBlock Text="llama-server启动时使用的 --chat-template 参数，如 rwkv-world、chatml、llama3 等" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="超时时间 (秒)" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppTimeout" Text="120" Height="35" Margin="0,2,0,10"/>

                            <!-- 翻译规则设置 -->
                            <TextBlock Text="翻译规则设置 (RWKV官方续写格式)" FontWeight="Bold" FontSize="13" Foreground="#3498DB" Margin="0,10,0,8"/>
                            <TextBlock Text="参考: https://www.rwkv.cn/docs/RWKV-Prompts/Completion-Prompts" 
                                       FontSize="11" Foreground="#3498DB" Margin="0,0,0,8" TextWrapping="Wrap"/>
                            <TextBlock Text="官方格式: {语言全名}: + 换行 + {文本} + 换行 + {目标语言全名}:" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="EOS停止符号" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppEosToken" Text="" Height="35" Margin="0,2,0,5"/>
                            <TextBlock Text="模型生成遇到此符号时停止，留空则使用模型默认EOS" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="翻译英文时的分隔符" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppEnSeparator" Text="\n\nEnglish" Height="35" Margin="0,2,0,5"/>
                            <TextBlock Text="prompt中目标语言前缀（默认 \n\nEnglish，即换两行后写 English:）" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="翻译中文时的分隔符" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppZhSeparator" Text="\n\nChinese" Height="35" Margin="0,2,0,5"/>
                            <TextBlock Text="prompt中目标语言前缀（默认 \n\nChinese，即换两行后写 Chinese:）" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <TextBlock Text="翻译日语时的分隔符" FontWeight="Bold" Margin="0,5"/>
                            <TextBox x:Name="llamaCppJaSeparator" Text="\n\nJapanese" Height="35" Margin="0,2,0,5"/>
                            <TextBlock Text="prompt中目标语言前缀（默认 \n\nJapanese，即换两行后写 Japanese:）" 
                                       FontSize="11" Foreground="Gray" Margin="0,0,0,10" TextWrapping="Wrap"/>

                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <Button Content="🧪 测试连接" Click="TestLlamaCppConnection" Width="100" Margin="0,0,10,0"/>
                                <Button Content="💾 保存配置" Click="SaveLlamaCppConfig" Width="100"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </ScrollViewer>
            </TabItem>

        </TabControl>
        
        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="#ECF0F1" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📁 打开配置目录" Click="OpenConfigDirectory" Width="120" Margin="0,0,10,0"/>
                <Button Content="🔄 重置所有配置" Click="ResetAllConfigs" Width="120" Margin="0,0,10,0"/>
                <Button Content="✅ 确定" Click="CloseWindow" Width="80" IsDefault="True"/>
            </StackPanel>
        </Border>
        
    </Grid>
</Window>
