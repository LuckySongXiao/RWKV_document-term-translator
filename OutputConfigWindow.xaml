<Window x:Class="DocumentTranslator.OutputConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输出格式配置" Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Icon="logo.ico">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <Border Grid.Row="0" Background="#007BFF" Padding="10">
            <TextBlock Text="📋 输出格式配置" FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- 配置区域 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
            <StackPanel>

                <!-- 输出格式选择 -->
                <Border BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="📋 输出格式" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <RadioButton x:Name="BilingualVerticalRadio" Content="📋 双语对照（原文在上，译文在下）" IsChecked="True" Margin="0,5"/>
                        <RadioButton x:Name="BilingualSideBySideRadio" Content="📊 并排对照（左右分栏）" Margin="0,5"/>
                        <RadioButton x:Name="InlineRadio" Content="📝 行内对照（在原文中插入译文）" Margin="0,5"/>
                        <RadioButton x:Name="OriginalOnlyRadio" Content="📄 仅原文" Margin="0,5"/>
                        <RadioButton x:Name="TranslatedOnlyRadio" Content="🌐 仅译文" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- 分段模式选择 -->
                <Border BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🔤 分段模式" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <RadioButton x:Name="ParagraphSegmentRadio" Content="📝 按段落分段" IsChecked="True" Margin="0,5"/>
                        <RadioButton x:Name="SentenceSegmentRadio" Content="🔤 按句子分段（智能识别句子边界）" Margin="0,5"/>
                    </StackPanel>
                </Border>

                <!-- 原文样式配置 -->
                <Border BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="📄 原文样式" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="颜色：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="OriginalColorTextBox" Grid.Row="0" Grid.Column="1" Text="000000" Margin="0,5" Height="25"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="字号：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="OriginalFontSizeTextBox" Grid.Row="1" Grid.Column="1" Text="12" Margin="0,5" Height="25"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="粗体：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="OriginalBoldCheckBox" Grid.Row="2" Grid.Column="1" IsChecked="False" Margin="0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="斜体：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="OriginalItalicCheckBox" Grid.Row="3" Grid.Column="1" IsChecked="False" Margin="0,5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 译文样式配置 -->
                <Border BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🌐 译文样式" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="颜色：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TranslatedColorTextBox" Grid.Row="0" Grid.Column="1" Text="0000FF" Margin="0,5" Height="25"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="字号：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="TranslatedFontSizeTextBox" Grid.Row="1" Grid.Column="1" Text="12" Margin="0,5" Height="25"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="粗体：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="TranslatedBoldCheckBox" Grid.Row="2" Grid.Column="1" IsChecked="True" Margin="0,5"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="斜体：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="TranslatedItalicCheckBox" Grid.Row="3" Grid.Column="1" IsChecked="False" Margin="0,5"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- 术语高亮配置 -->
                <Border BorderBrush="#DEE2E6" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="🎨 术语高亮" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                        <CheckBox x:Name="EnableTermHighlightCheckBox" Content="启用术语高亮" IsChecked="True" Margin="0,5"/>
                        
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="颜色：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox x:Name="HighlightColorTextBox" Grid.Row="0" Grid.Column="1" Text="FF0000" Margin="0,5" Height="25"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="粗体：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="HighlightBoldCheckBox" Grid.Row="1" Grid.Column="1" IsChecked="True" Margin="0,5"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="下划线：" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <CheckBox x:Name="HighlightUnderlineCheckBox" Grid.Row="2" Grid.Column="1" IsChecked="True" Margin="0,5"/>
                        </Grid>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>

        <!-- 底部按钮 -->
        <Border Grid.Row="2" Background="#F8F9FA" BorderBrush="#E9ECEF" BorderThickness="0,1,0,0" Padding="10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="ResetButton" Content="重置默认" Click="Reset_Click" Width="100" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="CancelButton" Content="取消" Click="Cancel_Click" Width="80" Height="30" Margin="0,0,10,0"/>
                <Button x:Name="ApplyButton" Content="应用" Click="Apply_Click" Width="80" Height="30" Background="#007BFF" Foreground="White" BorderThickness="0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
